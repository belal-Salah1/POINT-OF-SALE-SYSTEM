<Window x:Class="POSSystem.Views.SignupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign Up"
        Height="560" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <StackPanel Margin="40,30">
        <TextBlock Text="Create Account" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
        <TextBlock Text="New cashiers register here. Admins must be created from the Users panel by an existing admin."
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,20"/>

        <TextBlock Text="Full Name" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBox x:Name="FullNameBox" Margin="0,0,0,12"/>

        <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBox x:Name="UsernameBox" Margin="0,0,0,12"/>

        <TextBlock Text="Password (min 6 chars)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12"/>

        <TextBlock Text="Confirm Password" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,12"/>

        <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap" Visibility="Collapsed"/>
        <TextBlock x:Name="SuccessText" Foreground="{StaticResource SuccessBrush}" FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap" Visibility="Collapsed"/>

        <Button Content="Create Account" Style="{StaticResource PrimaryButton}" Height="44" Margin="0,12,0,0" Click="SignupButton_Click"/>
        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Height="44" Margin="0,8,0,0" Click="CancelButton_Click"/>
    </StackPanel>
</Window>
