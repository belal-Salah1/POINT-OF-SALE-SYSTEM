<Window x:Class="POSSystem.Views.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product"
        Height="540" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <StackPanel Margin="30">
        <TextBlock x:Name="TitleText" Text="Add Product" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="Name *" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox" Margin="0,0,0,12"/>

        <TextBlock Text="Barcode" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBox x:Name="BarcodeBox" Margin="0,0,0,12"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Cost *" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="CostBox" Text="0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Price *" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="PriceBox" Text="0"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Stock *" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="StockBox" Text="0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Min Stock (alert below)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="MinStockBox" Text="5"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Width="100" Click="Cancel_Click"/>
            <Button Content="Save"   Style="{StaticResource PrimaryButton}"   Width="100" Margin="8,0,0,0" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
