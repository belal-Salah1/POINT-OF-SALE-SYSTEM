<Window x:Class="POSSystem.Views.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt"
        Height="650" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">

    <DockPanel>
        <!-- Action buttons -->
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="🖨 Print" Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,8,0" Click="Print_Click"/>
                <Button Content="Close"     Style="{StaticResource SecondaryButton}" Width="120" Click="Close_Click"/>
            </StackPanel>
        </Border>

        <!-- Receipt content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <Border x:Name="ReceiptContent" Background="White" Padding="24" CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="🛒 POS System" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Sales Receipt" FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,12"/>

                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1" Padding="0,8">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Receipt #:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock x:Name="ReceiptNoText" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Date:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock x:Name="DateText" HorizontalAlignment="Right" FontSize="12"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Cashier:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock x:Name="CashierText" HorizontalAlignment="Right" FontSize="12"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Payment:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock x:Name="PaymentText" HorizontalAlignment="Right" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <ItemsControl x:Name="ItemsList" Margin="0,12,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ProductName}" FontSize="13" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center">
                                        <Run Text="{Binding Quantity}"/><Run Text=" × "/><Run Text="{Binding UnitPrice, StringFormat=N2}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="2" Text="{Binding Subtotal, StringFormat=N2}" FontSize="13" TextAlignment="Right" FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Subtotal:" FontSize="13"/>
                                <TextBlock x:Name="SubtotalText" HorizontalAlignment="Right" FontSize="13"/>
                            </Grid>
                            <Grid Margin="0,4,0,0">
                                <TextBlock x:Name="DiscountLabel" Text="Discount:" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="DiscountText" HorizontalAlignment="Right" FontSize="13" Foreground="{StaticResource DangerBrush}"/>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
                                <Grid>
                                    <TextBlock Text="TOTAL:" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock x:Name="TotalText" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Thank you for your purchase!" FontSize="13" HorizontalAlignment="Center" Margin="0,24,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="Please come again 🙏" FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </DockPanel>
</Window>
