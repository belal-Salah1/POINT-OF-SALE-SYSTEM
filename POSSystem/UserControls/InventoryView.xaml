<UserControl x:Class="POSSystem.UserControls.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource CardBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="24">
        <DockPanel Margin="20">

            <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="📦 Inventory" Style="{StaticResource HeadingLabel}"/>
                    <TextBlock Text="Manage products, prices, and stock levels" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔄 Refresh" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Refresh_Click"/>
                    <Button Content="+ Add Product" Style="{StaticResource PrimaryButton}" Click="Add_Click"/>
                </StackPanel>
            </Grid>

            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
                <TextBlock Grid.Column="0" Text="🔍 Search products..." IsHitTestVisible="False"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                           VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Border Grid.Column="1" Margin="12,0,0,0" Padding="12,8" Background="#FEF3C7" CornerRadius="6">
                    <TextBlock x:Name="LowStockText" FontSize="12" FontWeight="SemiBold" Foreground="#92400E"/>
                </Border>
            </Grid>

            <DataGrid x:Name="ProductsGrid">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"      Binding="{Binding Id}"                          Width="50"/>
                    <DataGridTextColumn Header="Name"    Binding="{Binding Name}"                        Width="*"/>
                    <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}"                     Width="140"/>
                    <DataGridTextColumn Header="Cost"    Binding="{Binding Cost,  StringFormat=N2}"      Width="80"/>
                    <DataGridTextColumn Header="Price"   Binding="{Binding Price, StringFormat=N2}"      Width="80"/>
                    <DataGridTextColumn Header="Stock"   Binding="{Binding Stock}"                       Width="70"/>
                    <DataGridTextColumn Header="Min"     Binding="{Binding MinStock}"                    Width="60"/>
                    <DataGridTemplateColumn Header="Actions" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Edit"   Padding="10,5" FontSize="12" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0" Click="Edit_Click"   Tag="{Binding}"/>
                                    <Button Content="Delete" Padding="10,5" FontSize="12" Style="{StaticResource DangerButton}"                  Click="Delete_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                <Setter Property="Background" Value="#FEF3C7"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
