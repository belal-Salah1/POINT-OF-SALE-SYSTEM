<UserControl x:Class="POSSystem.UserControls.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>

            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="📊 Reports" Style="{StaticResource HeadingLabel}"/>
                    <TextBlock Text="Sales analytics, profit, and best-selling products" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Date filters -->
            <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="From" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DatePicker x:Name="FromDate" Width="160" Padding="6"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="To" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DatePicker x:Name="ToDate" Width="160" Padding="6"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">
                        <Button Content="Apply"        Style="{StaticResource PrimaryButton}"   Padding="14,8" Click="Apply_Click"/>
                        <Button Content="Today"        Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="6,0,0,0" Click="Today_Click"/>
                        <Button Content="Last 7 Days"  Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="6,0,0,0" Click="Week_Click"/>
                        <Button Content="This Month"   Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="6,0,0,0" Click="Month_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- KPI cards -->
            <UniformGrid Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Sales Count" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SaleCountText" Text="0" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="Revenue" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <TextBlock x:Name="RevenueText" Text="0.00" FontSize="28" FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="Cost of Goods" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CostText" Text="0.00" FontSize="28" FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource DangerBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Profit" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ProfitText" Text="0.00" FontSize="28" FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Payment breakdown -->
            <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Payment Methods" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                    <UniformGrid Columns="3">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="💵 Cash" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="CashTotalText" Text="0.00" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Margin="4,0">
                            <TextBlock Text="💳 Card" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="CardTotalText" Text="0.00" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="📱 Mobile" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="MobileTotalText" Text="0.00" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Top products -->
            <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🏆 Top 5 Best Sellers" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                    <DataGrid x:Name="TopProductsGrid" MaxHeight="240">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}"                  Width="*"/>
                            <DataGridTextColumn Header="Quantity Sold" Binding="{Binding QuantitySold}"           Width="160"/>
                            <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat=N2}"     Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Recent sales -->
            <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="🧾 Sales in Selected Range" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                    <DataGrid x:Name="SalesGrid" MaxHeight="320">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"      Binding="{Binding Id}"                                                    Width="60"/>
                            <DataGridTextColumn Header="Date"    Binding="{Binding CreatedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"        Width="160"/>
                            <DataGridTextColumn Header="Cashier" Binding="{Binding CashierName}"                                           Width="*"/>
                            <DataGridTextColumn Header="Payment" Binding="{Binding PaymentMethod}"                                         Width="100"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N2}"                            Width="100"/>
                            <DataGridTextColumn Header="Discount %" Binding="{Binding Discount, StringFormat=N1}"                          Width="100"/>
                            <DataGridTextColumn Header="Total"   Binding="{Binding Total, StringFormat=N2}"                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
