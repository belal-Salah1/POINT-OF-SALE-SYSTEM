<UserControl x:Class="POSSystem.UserControls.CheckoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Product browser -->
        <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Checkout" Style="{StaticResource HeadingLabel}"/>
                    <TextBlock Text="Search products and add to cart" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,16"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Grid.Column="0" TextChanged="SearchBox_TextChanged"
                                 ToolTip="Search by name or barcode" />
                        <TextBlock Grid.Column="0" Text="🔍 Search by name or barcode..." IsHitTestVisible="False"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                                   VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <DataGrid x:Name="ProductsGrid" MouseDoubleClick="ProductsGrid_DoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"/>
                        <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="140"/>
                        <DataGridTextColumn Header="Price"   Binding="{Binding Price, StringFormat=N2}" Width="80"/>
                        <DataGridTextColumn Header="Stock"   Binding="{Binding Stock}"   Width="70"/>
                        <DataGridTemplateColumn Header="Action" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="+ Add" Style="{StaticResource PrimaryButton}" Padding="10,5" FontSize="12"
                                            Click="AddToCart_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                    <Setter Property="Background" Value="#FEF3C7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- RIGHT: Cart -->
        <Border Grid.Column="2" Background="{StaticResource CardBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="🛒 Cart" Style="{StaticResource HeadingLabel}"/>
                    <TextBlock x:Name="CartCountText" Text="0 items" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,16"/>
                </StackPanel>

                <!-- Bottom: totals + payment + complete -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Subtotal:" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="SubtotalText" Text="0.00" HorizontalAlignment="Right" FontSize="14"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Discount:" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="DiscountBox" Text="0" TextChanged="DiscountBox_TextChanged" Padding="8,4" HorizontalContentAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="%" FontSize="14" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Discount Amount:" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="DiscountAmountText" Text="-0.00" HorizontalAlignment="Right" FontSize="13" Foreground="{StaticResource DangerBrush}"/>
                            </Grid>

                            <Grid Margin="0,4,0,12">
                                <TextBlock Text="Total:" FontSize="20" FontWeight="Bold"/>
                                <TextBlock x:Name="TotalText" Text="0.00" HorizontalAlignment="Right" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>

                            <TextBlock Text="Payment Method" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,6"/>
                            <ComboBox x:Name="PaymentMethodBox" SelectedIndex="0" Margin="0,0,0,8" SelectionChanged="PaymentMethod_Changed">
                                <ComboBoxItem Content="Cash"/>
                                <ComboBoxItem Content="Card"/>
                                <ComboBoxItem Content="Mobile"/>
                            </ComboBox>

                            <!-- Cash given (only visible when Cash is selected) -->
                            <Grid x:Name="CashPanel" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Cash Received" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox x:Name="CashGivenBox" Text="0" TextChanged="CashGivenBox_TextChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="Change" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10" Background="#F9FAFB">
                                        <TextBlock x:Name="ChangeText" Text="0.00" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Button Content="✓ Complete Sale" Style="{StaticResource SuccessButton}" Height="48" FontSize="15" Click="CompleteSale_Click"/>
                            <Button Content="Clear Cart" Style="{StaticResource SecondaryButton}" Height="36" Margin="0,8,0,0" Click="ClearCart_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Cart items list -->
                <DataGrid x:Name="CartGrid" RowHeight="52">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="*"/>
                        <DataGridTemplateColumn Header="Qty" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="−" Width="26" Height="26" FontSize="14" FontWeight="Bold"
                                                Background="#F3F4F6" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                                Click="Decrement_Click" Tag="{Binding}" Cursor="Hand"/>
                                        <TextBlock Text="{Binding Quantity}" Width="28" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <Button Content="+" Width="26" Height="26" FontSize="14" FontWeight="Bold"
                                                Background="#F3F4F6" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                                Click="Increment_Click" Tag="{Binding}" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N2}" Width="80"/>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Width="26" Height="26" Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource DangerBrush}" FontWeight="Bold" Cursor="Hand"
                                            Click="RemoveFromCart_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
